# -----------------------------------------------------
# Bharat-Flow AI Environment Variables Template
# -----------------------------------------------------
# INSTRUCTIONS:
# 1. Rename this file from '.env.example' to '.env.local'
# 2. Fill in the keys below with your actual values
# 3. .env.local is safely ignored by Git to protect your secrets
# -----------------------------------------------------

# 1. Google Gemini (For Vision OCR & Voice Agent capabilities)
GEMINI_API_KEY="your_google_ai_studio_api_key_here"

# 2. Supabase Settings (For Authentication & PostgreSQL Ledger Database)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_public_anon_key_here"

# Optional: Only needed if you want backend endpoints to forcefully bypass RLS rules 
# (Highly recommended keeping this ONLY in .env.local and never exposing to the frontend)
SUPABASE_SERVICE_ROLE_KEY="your_secret_service_role_key_here"
